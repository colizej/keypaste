# ============================================================
# KeyPaste — environment variables (example file)
# Copy this to .env on each environment and fill real values.
# The .env file is gitignored — never commit real secrets.
# ============================================================

# ---------- API (Django, used in api/) ----------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=keypaste.dramius.com,localhost,127.0.0.1
DATABASE_URL=postgres://user:password@localhost:5432/keypaste

# ---------- Email (optional, via ForwardEmail) ----------
DEFAULT_FROM_EMAIL=noreply@keypaste.dramius.com
SUPPORT_EMAIL=support@keypaste.dramius.com

# ---------- App (Swift) ----------
# Reserved for future use (e.g. crash report endpoint URL).
KEYPASTE_API_BASE_URL=https://keypaste.dramius.com/api/v1
